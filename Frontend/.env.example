# API Configuration
VITE_API_BASE_URL=http://localhost:8080
# Optional legacy fallback token when no Supabase session exists
VITE_API_TOKEN=
VITE_API_FALLBACK_URL=your_backup_url_here

# Supabase Configuration
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key
# Legacy alias (optional, backward compatibility)
VITE_SUPABASE_ANON_KEY=

# Pagination
VITE_ARCHIVES_PER_PAGE=10
VITE_STORES_PER_PAGE=20 #deafult 20 and max 100
VITE_PRODUCTS_PER_PAGE=20 #default 20 and max 100

# Product Images
VITE_IMAGE_BASE_URL=https://your_domain_here/images/