# =================================================================================
# Environment Configuration (Docker/General)
# =================================================================================
# Copy this file to .env and customize for your environment
# This configuration is optimized for Docker Compose deployment
# =================================================================================

# =================
# Application Settings
# =================
VERSION=0.1.0
DEBUG=true
DEV_MODE=true
TIMEZONE=Europe/Zagreb

# =================
# Server Configuration
# =================
HOST=0.0.0.0
PORT=8080
BASE_URL=http://localhost:8080
REDIRECT_URL=http://localhost:8080/docs
# Comma-separated list of allowed CORS origins
CORS_ALLOW_ORIGINS=http://localhost:5173

# =================
# Database Configuration
# =================
# PostgreSQL connection settings (for Docker containers)
POSTGRES_DB=cijene
POSTGRES_USER=cijene_user
POSTGRES_PASSWORD=cijene_pass
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Database connection string (uses Docker service name 'db')
DB_DSN=postgresql://cijene_user:cijene_pass@db/cijene
DB_MIN_CONNECTIONS=5
DB_MAX_CONNECTIONS=30
# Keep latest N days of price-related data (0 = keep all history)
DB_RETENTION_DAYS=0
# Admin audit log retention in days (default target: 90)
AUDIT_LOG_RETENTION_DAYS=90

# Product search ranking (FTS + prefix + trigram)
SEARCH_FTS_WEIGHT=0.70
SEARCH_PREFIX_WEIGHT=0.20
SEARCH_TRIGRAM_WEIGHT=0.10
SEARCH_TRIGRAM_THRESHOLD_SHORT=0.32
SEARCH_TRIGRAM_THRESHOLD_LONG=0.24
SEARCH_TRIGRAM_LONG_QUERY_LEN=5

# Cart optimization defaults
CART_OPTIMIZE_DEFAULT_MAX_DISTANCE_KM=15
CART_OPTIMIZE_DEFAULT_MAX_STORES=5
CART_OPTIMIZE_ENUM_STORE_LIMIT=20
CART_OPTIMIZE_CACHE_ENABLED=true
CART_OPTIMIZE_CACHE_BACKEND=memory
CART_OPTIMIZE_CACHE_TTL_SECONDS=900
CART_OPTIMIZE_CACHE_LOCATION_BUCKET_M=200
CART_OPTIMIZE_CACHE_VERSION=v1
CART_OPTIMIZE_CACHE_REDIS_URL=redis://redis:6379/0
CART_OPTIMIZE_TUNING_ENABLED=true
CART_OPTIMIZE_TUNING_LOOKBACK_DAYS=30
CART_OPTIMIZE_TUNING_MIN_FEEDBACK_SAMPLES=20
CART_OPTIMIZE_TUNING_ACCEPTANCE_THRESHOLD=0.25
CART_OPTIMIZE_TUNING_DELTA=0.05
CART_OPTIMIZE_TUNING_CACHE_TTL_SECONDS=300

# Supabase authentication (JWKS-based, required for JWT-protected /v1 endpoints)
SUPABASE_URL=https://your-project-id.supabase.co
# Optional legacy fallback for old shared-secret JWT verification
SUPABASE_JWT_SECRET=
# Optional: needed for admin user deletion sync with Supabase Auth
SUPABASE_SERVICE_ROLE_KEY=

# =================
# Data Storage (Relative Paths)
# =================
# These paths are relative and work in both Docker and local environments
# Docker: resolves to /app/data and /app/output (working dir is /app)
# Local: resolves to ./data and ./output (working dir is project root)
ARCHIVE_DIR=data
CRAWLER_OUTPUT_DIR=output

# =================
# Google Maps Store Enrichment
# =================
# Required for service.db.enrich_missing_store_coords
GOOGLE_MAPS_API_KEY=
GOOGLE_MAPS_TIMEOUT_SECONDS=20
GOOGLE_MAPS_REQUEST_DELAY_SECONDS=0.15
GOOGLE_MAPS_MAX_RETRIES=3
GOOGLE_MAPS_RETRY_BACKOFF_SECONDS=0.8
GOOGLE_MAPS_LANGUAGE=hr
GOOGLE_MAPS_REGION=hr
GOOGLE_MAPS_COUNTRY_HINT=Croatia
GOOGLE_MAPS_ENABLE_GEOCODING_FALLBACK=true